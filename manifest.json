{
    "manifest_version": 2,
    "name": "DOI Manager",
    "version": "2.0.0",
    "description": "Plugin for fetching and validating DOI and shortDOI names",
    "author": "Brenton M. Wiernik",
    "icons": {
      "48": "skin/icon.png",
      "96": "skin/icon@2x.png"
    },
    "applications": {
